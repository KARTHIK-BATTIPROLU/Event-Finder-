# ════════════════════════════════════════
# EventRadar — environment configuration
# ════════════════════════════════════════
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# ── REQUIRED ────────────────────────────────────────────────────────────────────
# Free MongoDB Atlas M0 connection string.
# Create a free cluster at https://cloud.mongodb.com → Connect → Drivers → Python
# Default (used when MONGO_URI is absent): connects to localhost:27017
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Optional: override the database name (default: event_radar)
# MONGO_DB_NAME=event_radar

# ── OPTIONAL — key-gated sources (skipped gracefully when absent) ────────────────
# Eventbrite: https://www.eventbrite.com/platform/api/keys/
# EVENTBRITE_TOKEN=

# Meetup: https://www.meetup.com/api/oauth/list/
# MEETUP_TOKEN=

# Luma Plus API: https://lu.ma/dashboard/api
# LUMA_API_KEY=

# ── OPTIONAL — LLM normalization (off by default; enabled when any key is set) ──
# Gemini: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=

# OpenAI: https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# Anthropic: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=

# ── OPTIONAL — tuning (sensible defaults shown) ──────────────────────────────────
# HTTP_TIMEOUT=15
# HTTP_RETRIES=3
# HTTP_BACKOFF_BASE=2.0
# HTTP_PAGE_WAIT=2.0
# RUNNER_MAX_WORKERS=6
# DEDUP_SIMILARITY_THRESHOLD=0.82
# DEDUP_DATE_WINDOW_DAYS=3
# CORPORATE_SEED_WINDOW_DAYS=60
